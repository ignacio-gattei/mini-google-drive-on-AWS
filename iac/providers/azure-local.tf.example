# Provider Azure apuntando a Azurite (emulador de Blob / Queue / Table).
#
# Para usar: renombrar a azure-local.tf
# Limitación: Azurite emula SOLO storage. Para otros servicios Azure necesitás
# Azure real (no hay emulador open-source equivalente a LocalStack).
#
# Azurite default credentials:
#   account: devstoreaccount1
#   key:     Eby8vdM02xNOcqFlqUwJPLlmEEHlCxC5...
#   blob:    http://localhost:10000

terraform {
  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 3.0"
    }
  }
}

provider "azurerm" {
  features {}

  # Credenciales de Azurite (no son reales — fake account)
  skip_provider_registration  = true
  storage_use_azuread         = false

  # NOTA: el azurerm provider habla con ARM (management API), no con Azurite.
  # Para gestionar storage CONTRA Azurite en serio, conviene:
  #   1. Manejar el storage account directamente con `azurite` o el SDK
  #   2. Usar `azapi` provider para llamar directo al endpoint
  #   3. O ir a Azure real (Free Tier por 12 meses)
  #
  # Este archivo está como referencia del shape — la combinación
  # terraform+Azurite es awkward en la práctica.
}

# Recursos de ejemplo (descomentá si vas a usar):
#
# resource "azurerm_resource_group" "main" {
#   name     = "${var.project_name}-rg"
#   location = "eastus"
# }
