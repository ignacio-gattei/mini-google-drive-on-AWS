# Provider GCP apuntando a emuladores locales.
#
# Para usar: renombrar a gcp-local.tf
# Limitación: similar a Azure — los emuladores de GCP cubren storage / pubsub /
# firestore pero no toda la API de management. Algunos recursos del provider
# google requieren API real para `apply`.
#
# Emuladores comunes:
#   - Cloud Storage: fake-gcs-server  (puerto 4443)
#   - Pub/Sub:       gcloud beta emulators pubsub start
#   - Firestore:     gcloud beta emulators firestore start
#
# El SDK respeta env vars: STORAGE_EMULATOR_HOST, PUBSUB_EMULATOR_HOST, etc.

terraform {
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 5.0"
    }
  }
}

provider "google" {
  project = var.project_name
  region  = var.region

  # GCP no tiene un endpoint override tan limpio como AWS — el provider habla
  # con la Resource Manager API real. Para usar contra emuladores:
  #   - exportar STORAGE_EMULATOR_HOST=http://localhost:4443 antes de apply
  #   - o ir a GCP real (Free Tier $300 USD por 90 días)
  #
  # Este archivo está como referencia del shape — para CRUD de Cloud Storage
  # contra fake-gcs-server, conviene usar el SDK directo, no terraform.
}

# Recurso de ejemplo (requiere GCP real para `apply` con google provider):
#
# resource "google_storage_bucket" "data" {
#   name     = "${var.project_name}-data"
#   location = "US"
# }
